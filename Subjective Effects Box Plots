# ============================================================
#  Subjective Effects Box & Whisker Plot
# ============================================================
library(ggplot2)
library(tidyr)
library(dplyr)

# ── 1. DATA ──────────────────────────────────────────────────
data_list <- list(

  P0016 = data.frame(
    timepoint    = paste0("T", 1:9),
    Drug_effects = c(0, 3, 4, 4, 4, 3, 1, 1, 1),
    MEQ1         = c(0, 2, 4, 3, 3, 1, 1, 1, 0),
    MEQ2         = c(1, 2, 3, 2, 2, 4, 4, 3, 3),
    MEQ3         = c(0, 2, 4, 3, 4, 3, 1, 0, 0),
    MEQ4         = c(0, 2, 3, 3, 5, 3, 3, 1, 1)
  ),
  P0005 = data.frame(
    timepoint    = paste0("T", 1:9),
    Drug_effects = c(0, 0, 1, 2, 2, 3, 3, 3, 2),
    MEQ1         = c(1, 0, 1, 2, 4, 4, 4, 5, 5),
    MEQ2         = c(4, 4, 4, 4, 4, 4, 3, 5, 5),
    MEQ3         = c(0, 1, 1, 2, 2, 4, 3, 5, 5),
    MEQ4         = c(0, 0, 0, 1, 1, 3, 1, 1, 1)
  ),
  P0007 = data.frame(
    timepoint    = paste0("T", 1:9),
    Drug_effects = c(0, 1, 2, 2, 2, 3, 4, 4, 2),
    MEQ1         = c(1, 2, 2, 3, 3, 4, 5, 5, 4),
    MEQ2         = c(3, 3, 3, 3, 4, 4, 4, 5, 3),
    MEQ3         = c(1, 1, 2, 2, 3, 4, 5, 5, 2),
    MEQ4         = c(2, 2, 2, 3, 2, 3, 5, 4, 2)
  ),
  P0008 = data.frame(
    timepoint    = paste0("T", 1:9),
    Drug_effects = c(0, 4, 5, NA, NA, 5, 2, 1, 1),
    MEQ1         = c(1, 2, 4, NA, NA, 5, 3, 3, 3),
