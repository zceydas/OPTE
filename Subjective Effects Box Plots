    MEQ3         = c(0, 3, 5, NA, NA, 5, 2, 2, 1),
    MEQ4         = c(0, 4, 5, NA, NA, 5, 2, 2, 2)
  ),
  P0011 = data.frame(
    timepoint    = paste0("T", 1:9),
    Drug_effects = c(0, 0, 2, 3, 3, 4, 4, 3, 2),
    MEQ1         = c(2, 1, 1, 2, 1, 3, 3, 3, 3),
    MEQ2         = c(4, 4, 4, 4, 4, 5, 5, 5, 5),
    MEQ3         = c(0, 0, 0, 1, 1, 2, 1, 3, 0),
    MEQ4         = c(0, 0, 0, 0, 1, 1, 1, 1, 0)
  ),
  P0012 = data.frame(
    timepoint    = paste0("T", 1:9),
