# ── 2. COMBINE & RESHAPE ─────────────────────────────────────
df <- bind_rows(data_list, .id = "participant") |>
  mutate(MEQ_total = MEQ1 + MEQ2 + MEQ3 + MEQ4) |>  # <-- add this
  pivot_longer(cols = c(Drug_effects, MEQ1, MEQ2, MEQ3, MEQ4, MEQ_total),
               names_to  = "measure",
               values_to = "score") |>
  mutate(
    timepoint = factor(timepoint, levels = paste0("T", 1:9)),
    measure   = factor(measure,
                       levels = c("Drug_effects","MEQ1","MEQ2","MEQ3","MEQ4","MEQ_total"),
                       labels = c("Drug Effects","MEQ1","MEQ2","MEQ3","MEQ4","MEQ Total"))
  )

# Print n per timepoint (useful for checking missing data)
df |>
  group_by(measure, timepoint) |>
  summarise(n = sum(!is.na(score)), .groups = "drop") |>
  print()

# ── 3. PLOT ──────────────────────────────────────────────────
# Measures to include in each plot
measures_individual <- c("Drug Effects", "MEQ1", "MEQ2", "MEQ3", "MEQ4")
measures_total      <- c("MEQ Total")

# ── Plot 1: individual measures (y = 0–5) ──
p1 <- ggplot(df |> filter(measure %in% measures_individual), aes(x = timepoint, y = score)) +
  geom_boxplot(aes(fill = measure), outlier.shape = NA,
               width = 0.55, alpha = 0.75, colour = "grey30", linewidth = 0.4) +
  geom_jitter(aes(colour = measure), width = 0.12, size = 1.8, alpha = 0.9, shape = 16) +
  stat_summary(fun.data = function(x) data.frame(y = -0.25, label = sum(!is.na(x))),
               geom = "text", size = 2.8, colour = "grey50") +
  facet_wrap(~ measure, nrow = 1) +
  scale_fill_manual(values  = c("#4C72B0","#DD8452","#55A868","#C44E52","#8172B3")) +
  scale_colour_manual(values = c("#2a5298","#b85a20","#2e7d4f","#8b1a1a","#4a3a8a")) +
  scale_y_continuous(breaks = 0:5, limits = c(-0.5, 5.5)) +
  labs(title = "Subjective Effects by Timepoint",
       subtitle = "Box = IQR, line = median, points = individual scores, number = n",
       x = "Timepoint", y = "Score") +
  theme_minimal(base_size = 12) +
  theme(legend.position = "none",
        strip.text = element_text(face = "bold", size = 11),
        plot.title = element_text(face = "bold", size = 14),
        plot.subtitle = element_text(colour = "grey50", size = 10),
        panel.grid.minor = element_blank(),
        panel.grid.major.x = element_blank(),
        axis.text.x = element_text(size = 9))

# ── Plot 2: MEQ Total (y = 0–20) ──
p2 <- ggplot(df |> filter(measure %in% measures_total), aes(x = timepoint, y = score)) +
  geom_boxplot(fill = "#937860", outlier.shape = NA,
               width = 0.55, alpha = 0.75, colour = "grey30", linewidth = 0.4) +
  geom_jitter(colour = "#5c4a30", width = 0.12, size = 1.8, alpha = 0.9, shape = 16) +
  stat_summary(fun.data = function(x) data.frame(y = -0.5, label = sum(!is.na(x))),
               geom = "text", size = 2.8, colour = "grey50") +
  scale_y_continuous(breaks = seq(0, 20, 2), limits = c(-1, 21)) +
  labs(title = "MEQ Total Score by Timepoint",
       subtitle = "Box = IQR, line = median, points = individual scores, number = n",
       x = "Timepoint", y = "Total Score (0–20)") +
  theme_minimal(base_size = 12) +
  theme(legend.position = "none",
        plot.title = element_text(face = "bold", size = 14),
        plot.subtitle = element_text(colour = "grey50", size = 10),
        panel.grid.minor = element_blank(),
        panel.grid.major.x = element_blank(),
        axis.text.x = element_text(size = 9))

